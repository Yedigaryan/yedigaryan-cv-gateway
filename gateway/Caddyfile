# Caddy config for the public Render edge of the LLM gateway.
# Render terminates TLS upstream, so auto_https stays off.
# All public traffic must carry `Authorization: Bearer $LLM_API_TOKEN`
# except the /health probe (Render orchestration) and CORS preflights.
#
# CORS uses Access-Control-Allow-Origin: * because the resource is bearer-
# token-gated — anyone with the token can call it from anywhere, so the
# CORS check adds no security beyond what the bearer already enforces. We
# explicitly do NOT set Access-Control-Allow-Credentials, which keeps the
# wildcard origin valid (browsers only reject `*` when credentials: 'include').

{
    # Render terminates TLS upstream — Caddy must not bind 80/443.
    auto_https off

    # Disable Caddy's admin API entirely. We configure the gateway
    # statically through this file; runtime config changes via the REST
    # admin endpoint are not used. Disabling it stops the trickle of
    # `admin.api` "host not allowed" 403s from external port scanners and
    # removes a small attack surface. To re-enable for live debugging:
    # comment this line out and `kubectl exec`/Render-shell to localhost:2019.
    admin off
}

:{$PORT:10000} {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # CORS — applied to every response, including 401s.
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "POST, GET, OPTIONS"
        Access-Control-Allow-Headers "Authorization, Content-Type"
        Access-Control-Max-Age "86400"
    }

    # Render orchestration probe — always open.
    handle /health {
        respond "OK" 200
    }

    # CORS preflight — must answer before the auth check, or the browser
    # never sends the real request.
    @preflight method OPTIONS
    handle @preflight {
        respond "" 204
    }

    # Authenticated traffic flows through the Tailscale tunnel to the
    # laptop running Ollama at $LLM_BACKEND (e.g. 100.x.y.z:11434).
    @authorized header Authorization "Bearer {$LLM_API_TOKEN}"
    handle @authorized {
        # Caddy dials localhost:18080 — a socat listener (see run.sh) that
        # tunnels each TCP connection through Tailscale's HTTP-CONNECT
        # proxy to ${LLM_BACKEND} on the laptop. From Caddy's perspective
        # this is a normal direct dial; the tunneling is transparent.
        reverse_proxy localhost:18080 {
            # Override Host with the literal upstream so Ollama's anti-
            # DNS-rebinding origin-check sees a "trusted" host. Without
            # this Ollama returns 301/403 because the Host header would
            # otherwise be the public Render hostname.
            header_up Host "localhost:11434"
            header_up X-Forwarded-For {remote_host}

            transport http {
                # Ollama's first response after a cold model load can
                # take 30-120s. Caddy's 30s default would 502 mid-stream.
                read_timeout 300s
                write_timeout 300s
                dial_timeout 10s
            }
        }
    }

    handle {
        respond "Unauthorized" 401 {
            close
        }
    }

    log {
        output stdout
        format json
    }
}
